---
import "../styles/global.css";
import Header from "./Header.astro";

interface Props {
  pageTitle: string;
  articles: any[];
}
const { pageTitle, articles } = Astro.props;

function formatDate(date: string) {
  return new Date(date).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' });
}
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <title>{pageTitle} — Creoo Testing Lab</title>
  </head>
  <body>
    <Header />

    <main class="ag-main">
      <h2 class="ag-title">{pageTitle}</h2>
      {articles.length === 0 ? (
        <p class="ag-empty">No articles yet.</p>
      ) : (
        <div class="ag-grid">
          {articles.map(article => (
            <a href={article.url} class="ag-card">
              <img src={article.frontmatter.image || '/images/rune-1.png'} alt={article.frontmatter.title} class="ag-img" />
              <h3 class="ag-card-title">{article.frontmatter.title}</h3>
              <span class="ag-date">{formatDate(article.frontmatter.date)}</span>
            </a>
          ))}
        </div>
      )}
    </main>
  </body>
</html>

<style>
  .ag-main {
    padding: 1.5rem 2rem 2rem;
  }

  .ag-title {
    font-family: monospace;
    font-size: 0.95rem;
    font-weight: 500;
    color: #1C1D21;
    text-transform: uppercase;
    margin: 0 0 1rem 0;
  }

  .ag-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(22vw, 1fr));
    gap: 2rem 1.5rem;
  }

  .ag-card {
    text-decoration: none;
    color: #1C1D21;
    display: flex;
    flex-direction: column;
    align-self: start;
    transition: opacity 0.2s ease;
  }

  .ag-card:hover {
    opacity: 0.8;
  }

  .ag-img {
    width: 100%;
    aspect-ratio: 3 / 2;
    object-fit: cover;
    display: block;
  }

  .ag-card-title {
    font-size: 1.25rem;
    font-weight: 500;
    margin: 0.5rem 0 0.2rem;
    line-height: 1.35;
  }

  .ag-date {
    font-family: monospace;
    font-size: 0.88rem;
    color: #75798a;
  }

  .ag-empty {
    font-size: 0.95rem;
    color: #75798a;
    font-family: monospace;
  }
</style>
