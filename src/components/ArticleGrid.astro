---
import "../styles/global.css";
import Header from "./Header.astro";

interface Props {
  pageTitle: string;
  articles: any[];
}
const { pageTitle, articles } = Astro.props;

function formatDate(date: string) {
  return new Date(date).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' });
}

function halves<T>(arr: T[]): [T[], T[]] {
  const mid = Math.ceil(arr.length / 2);
  return [arr.slice(0, mid), arr.slice(mid)];
}

function gridColClass(count: number) {
  let classes = "ag-grid-col";
  if (count < 4) classes += " ag-grid-col-rows-auto";
  return classes;
}

const pages: any[][] = [];
for (let i = 0; i < articles.length; i += 8) {
  pages.push(articles.slice(i, i + 8));
}
const totalPages = pages.length;
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <title>{pageTitle} — Creoo Testing Lab</title>
  </head>
  <body>
    <Header />

    <main class="ag-main">
      <h2 class="ag-title">{pageTitle}</h2>
      <div class="ag-viewport">
        <div class="ag-track" id="ag-track">
          {pages.length === 0 ? (
            <div class="ag-page ag-page-full">
              <p class="ag-empty">No articles yet.</p>
            </div>
          ) : (
            pages.map(page => (
              <div class="ag-page ag-page-full">
                {halves(page).map(half => (
                  half.length > 0 && (
                    <div class={gridColClass(half.length)}>
                      {half.map(article => (
                        <a href={article.url} class="ag-card">
                          <img src={article.frontmatter.image || '/images/rune-1.png'} alt={article.frontmatter.title} class="ag-img" />
                          <h3 class="ag-card-title">{article.frontmatter.title}</h3>
                          <span class="ag-date">{formatDate(article.frontmatter.date)}</span>
                        </a>
                      ))}
                    </div>
                  )
                ))}
              </div>
            ))
          )}
        </div>
      </div>

      {totalPages > 1 && (
        <div class="ag-pagination">
          <button class="ag-page-btn" id="ag-prev" disabled>&larr; Back</button>
          <button class="ag-page-btn" id="ag-next">Next &rarr;</button>
        </div>
      )}
    </main>

    <script>
      (() => {
        const track = document.getElementById('ag-track');
        if (!track) return;
        const prevButton = document.getElementById('ag-prev') as HTMLButtonElement | null;
        const nextButton = document.getElementById('ag-next') as HTMLButtonElement | null;
        if (!prevButton || !nextButton) return;

        const pages = track.querySelectorAll('.ag-page');
        let current = 0;
        const total = pages.length;

        function updatePagination() {
          if (!prevButton || !nextButton || !track) return;
          prevButton.disabled = current === 0;
          nextButton.disabled = current === total - 1;
          track.style.transform = `translateX(-${current * 100}%)`;
        }

        prevButton.addEventListener('click', () => {
          if (current > 0) { current--; updatePagination(); }
        });

        nextButton.addEventListener('click', () => {
          if (current < total - 1) { current++; updatePagination(); }
        });
      })();
    </script>
  </body>
</html>

<style>
  .ag-main {
    height: calc(100vh - 9rem);
    overflow: hidden;
    position: relative;
    display: flex;
    flex-direction: column;
  }

  .ag-title {
    font-family: monospace;
    font-size: 0.95rem;
    font-weight: 500;
    color: #1C1D21;
    text-transform: uppercase;
    margin: 0;
    padding: 1rem 2rem 0.5rem 2rem;
    flex-shrink: 0;
  }

  .ag-viewport {
    flex: 1;
    overflow: hidden;
    position: relative;
  }

  .ag-track {
    display: flex;
    height: 100%;
    transition: none;
    will-change: transform;
  }

  .ag-page {
    min-width: 100%;
    height: 100%;
    box-sizing: border-box;
    padding: 1rem 2rem;
  }

  .ag-page-full {
    display: flex;
    gap: 2rem;
  }

  .ag-grid-col {
    flex: 1;
    max-width: calc(50% - 1rem);
    display: grid;
    grid-template-columns: 1fr 1fr;
    grid-template-rows: 1fr 1fr;
    row-gap: 1.5rem;
    column-gap: 1rem;
    min-width: 0;
  }

  .ag-grid-col-rows-auto {
    grid-template-rows: auto auto;
    align-content: start;
  }

  .ag-card {
    text-decoration: none;
    color: #1C1D21;
    display: flex;
    flex-direction: column;
    min-height: 0;
    align-self: start;
    transition: opacity 0.2s ease;
  }

  .ag-card:hover {
    opacity: 0.8;
  }

  .ag-img {
    width: 100%;
    aspect-ratio: 3 / 2;
    object-fit: cover;
    image-rendering: pixelated;
    display: block;
  }

  .ag-card-title {
    font-size: 1.3rem;
    font-weight: 500;
    text-transform: uppercase;
    color: #1C1D21;
    margin: 0.5rem 0 0 0;
    line-height: 1.3;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    background-color: #e8dfc6;
    padding: 0.1rem 0.5rem;
    text-decoration: underline;
    text-decoration-thickness: 2px;
  }

  .ag-date {
    font-size: 0.85rem;
    color: #75798a;
    font-family: monospace;
    margin-top: 0.15rem;
  }

  .ag-empty {
    font-size: 0.95rem;
    color: #75798a;
    font-family: monospace;
  }

  .ag-pagination {
    display: flex;
    justify-content: center;
    gap: 2rem;
    padding: 0.8rem 0;
    flex-shrink: 0;
  }

  .ag-page-btn {
    background: none;
    border: none;
    font-size: 0.95rem;
    font-weight: 500;
    color: #1C1D21;
    cursor: pointer;
    padding: 0.3rem 0.8rem;
    transition: color 0.2s ease;
    font-family: inherit;
  }

  .ag-page-btn:hover:not(:disabled) {
    color: #474747;
  }

  .ag-page-btn:disabled {
    color: #c8c0ab;
    cursor: default;
  }

  @media (max-width: 768px) {
    .ag-grid-col {
      grid-template-columns: 1fr 1fr;
      grid-template-rows: auto;
      max-width: none;
    }

    .ag-page-full {
      flex-direction: column;
      overflow-y: auto;
    }
  }
</style>
