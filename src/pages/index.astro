---
import "../styles/global.css";
import Header from "../components/Header.astro";

const articleFiles = import.meta.glob('./articles/*.md', { eager: true });
const allArticles = Object.values(articleFiles) as any[];
const pinnedArticles = allArticles
  .filter(a => a.frontmatter.pinned === true)
  .filter(a => !a.frontmatter.hidden)
  .filter(a => import.meta.env.DEV || !a.frontmatter.draft)
  .sort((a, b) => new Date(b.frontmatter.date).getTime() - new Date(a.frontmatter.date).getTime())
  .slice(0, 3);

function formatDate(date: string) {
  return new Date(date).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' });
}
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <title>Creoo Testing Lab</title>
  </head>
  <body>
    <Header />
    <main class="home-main">
      <div class="home-container">
        <div class="home-left">
          <!-- Left side placeholder -->
        </div>
        <div class="home-right">
          <h2 class="featured-title">Featured Catalogue</h2>
          <div class="featured-grid">
            {pinnedArticles.map(article => (
              <a href={article.url} class="featured-card">
                <img
                  src={article.frontmatter.image || '/images/rune-1.png'}
                  alt={article.frontmatter.title}
                  class="featured-card-img"
                />
                <div class="featured-card-body">
                  <h3 class="featured-card-title">{article.frontmatter.title}</h3>
                  {article.frontmatter.description && (
                    <p class="featured-card-description">{article.frontmatter.description}</p>
                  )}
                  <span class="featured-card-date">{formatDate(article.frontmatter.date)}</span>
                </div>
              </a>
            ))}
          </div>
          <a href="/catalogue" class="featured-view-all">[view full catalogue]</a>
        </div>
      </div>
    </main>
  </body>
</html>

<style>
  .home-main {
    padding: 0;
    height: calc(100vh - 200px);
    overflow: hidden;
  }

  .home-container {
    display: grid;
    grid-template-columns: 1fr 50vw;
    height: 100%;
  }

  .home-left {
    padding: 2rem;
    overflow: hidden;
  }

  .home-right {
    padding: 2rem 0.75rem;
    display: flex;
    flex-direction: column;
    height: 100%;
    box-sizing: border-box;
  }

  .featured-title {
    font-size: 1.6rem;
    font-weight: 500;
    color: #1C1D21;
    margin: 0 0 1.4rem 0;
    text-transform: none;
    flex-shrink: 0;
  }

  .featured-grid {
    display: flex;
    flex-direction: column;
    gap: 1.4rem;
    flex: 1;
    align-content: flex-start;
  }

  .featured-card {
    text-decoration: none;
    color: #1C1D21;
    display: flex;
    flex-direction: row;
    gap: 1rem;
    align-items: flex-start;
    transition: opacity 0.2s ease;
  }

  .featured-card:hover {
    opacity: 0.75;
  }

  .featured-card-img {
    width: 190px;
    min-width: 190px;
    max-width: 190px;
    height: 127px;
    object-fit: cover;
    flex-shrink: 0;
    display: block;
  }

  .featured-card-body {
    flex: 1;
    display: flex;
    flex-direction: column;
  }

  .featured-card-title {
    font-size: 1.35rem;
    font-weight: 500;
    margin: 0 0 0.4rem 0;
    line-height: 1.3;
  }

  .featured-card-description {
    font-size: 1.05rem;
    color: #1C1D21;
    margin: 0 0 0.4rem 0;
    line-height: 1.5;
  }

  .featured-card-date {
    font-family: monospace;
    font-size: 0.82rem;
    color: #75798a;
    margin-top: auto;
  }

  .featured-view-all {
    display: block;
    flex-shrink: 0;
    text-align: center;
    padding: 1.4rem 0 0.5rem;
    font-family: monospace;
    font-size: 0.95rem;
    font-weight: 600;
    color: #15803d;
    text-decoration: none;
    transition: opacity 0.2s ease;
  }

  .featured-view-all:hover {
    opacity: 0.65;
  }

  @media (max-width: 768px) {
    .home-container {
      grid-template-columns: 1fr;
    }

    .home-left {
      display: none;
    }

    .home-right {
      border-left: none;
      padding: 1.5rem;
    }
  }
</style>
