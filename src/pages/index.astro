---
import "../styles/global.css";

const articleFiles = import.meta.glob('./articles/*.md', { eager: true });
const allArticles = Object.values(articleFiles) as any[];
const articles = allArticles
  .filter(a => !a.frontmatter.hidden)
  .sort((a, b) => new Date(b.frontmatter.date).getTime() - new Date(a.frontmatter.date).getTime());

const pinned = articles.filter(a => a.frontmatter.pinned).slice(0, 2);
const unpinned = articles.filter(a => !a.frontmatter.pinned);

const hasFeatured = pinned.length > 0;
const page1Count = hasFeatured ? 4 : 8;
const page1Standard = unpinned.slice(0, page1Count);
const remaining = unpinned.slice(page1Count);

// Split into pages of 8
const laterPages: typeof articles[] = [];
for (let i = 0; i < remaining.length; i += 8) {
  laterPages.push(remaining.slice(i, i + 8));
}

const totalPages = 1 + laterPages.length;

function formatDate(date: string) {
  return new Date(date).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' });
}

// Split array into two halves for the two-column grid
function halves<T>(arr: T[]): [T[], T[]] {
  const mid = Math.ceil(arr.length / 2);
  return [arr.slice(0, mid), arr.slice(mid)];
}
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <title>Creoo Testing Lab</title>
  </head>
  <body>
    <div class="header-container">
      <img src="/images/rune-1.png" alt="Rune" class="header-image">
      <div class="header-texts">
        <a href="/" class="plain-link"><h1 class="header">Creoo Testing Lab</h1></a>
        <div class="header-2">
          <span>Welcome to my laboratory, wanderer.</span>
        </div>
      </div>
      <nav class="lc-header-icons">
        <a href="#" class="lc-header-btn">
          <img src="/images/rune-1.png" alt="About" class="lc-header-btn-img" />
          <span class="lc-header-btn-label">about</span>
        </a>
        <a href="https://github.com/kingcreoo/website" class="lc-header-btn">
          <img src="/images/rune-1.png" alt="Open Source" class="lc-header-btn-img" />
          <span class="lc-header-btn-label">open<br>source</span>
        </a>
      </nav>
    </div>

    <hr class="header-divider">

    <main class="hp-main">
      <div class="hp-viewport">
        <div class="hp-track" id="hp-track">

          {/* Page 1 */}
          {hasFeatured ? (
            <div class="hp-page hp-page-featured">
              <div class="hp-featured-col">
                {pinned.map(article => (
                  <a href={article.url} class="hp-card hp-card-featured">
                    <img src={article.frontmatter.image || '/images/rune-1.png'} alt={article.frontmatter.title} class="hp-img-featured" />
                    <div class="hp-featured-text">
                      <h3 class="hp-title">{article.frontmatter.title}</h3>
                      <p class="hp-preview">{article.frontmatter.description}</p>
                      <span class="hp-date">{formatDate(article.frontmatter.date)}</span>
                    </div>
                  </a>
                ))}
              </div>
              {page1Standard.length > 0 && (
                <div class="hp-grid-col">
                  {page1Standard.map(article => (
                    <a href={article.url} class="hp-card hp-card-standard">
                      <img src={article.frontmatter.image || '/images/rune-1.png'} alt={article.frontmatter.title} class="hp-img-standard" />
                      <h3 class="hp-title-sm">{article.frontmatter.title}</h3>
                      <span class="hp-date">{formatDate(article.frontmatter.date)}</span>
                    </a>
                  ))}
                </div>
              )}
            </div>
          ) : (
            <div class="hp-page hp-page-full">
              {halves(page1Standard).map(half => (
                half.length > 0 && (
                  <div class="hp-grid-col">
                    {half.map(article => (
                      <a href={article.url} class="hp-card hp-card-standard">
                        <img src={article.frontmatter.image || '/images/rune-1.png'} alt={article.frontmatter.title} class="hp-img-standard" />
                        <h3 class="hp-title-sm">{article.frontmatter.title}</h3>
                        <span class="hp-date">{formatDate(article.frontmatter.date)}</span>
                      </a>
                    ))}
                  </div>
                )
              ))}
            </div>
          )}

          {/* Pages 2+ */}
          {laterPages.map(page => (
            <div class="hp-page hp-page-full">
              {halves(page).map(half => (
                half.length > 0 && (
                  <div class="hp-grid-col">
                    {half.map(article => (
                      <a href={article.url} class="hp-card hp-card-standard">
                        <img src={article.frontmatter.image || '/images/rune-1.png'} alt={article.frontmatter.title} class="hp-img-standard" />
                        <h3 class="hp-title-sm">{article.frontmatter.title}</h3>
                        <span class="hp-date">{formatDate(article.frontmatter.date)}</span>
                      </a>
                    ))}
                  </div>
                )
              ))}
            </div>
          ))}

        </div>
      </div>

      {totalPages > 1 && (
        <div class="hp-pagination">
          <button class="hp-page-btn hp-prev" id="hp-prev" disabled>&larr; Back</button>
          <button class="hp-page-btn hp-next" id="hp-next">Next &rarr;</button>
        </div>
      )}
    </main>

    <script>
      const track = document.getElementById('hp-track');
      const prevBtn = document.getElementById('hp-prev');
      const nextBtn = document.getElementById('hp-next');
      if (track && prevBtn && nextBtn) {
        const pages = track.querySelectorAll('.hp-page');
        let current = 0;
        const total = pages.length;

        function updatePagination() {
          prevBtn.disabled = current === 0;
          nextBtn.disabled = current === total - 1;
          track.style.transform = `translateX(-${current * 100}%)`;
        }

        prevBtn.addEventListener('click', () => {
          if (current > 0) { current--; updatePagination(); }
        });

        nextBtn.addEventListener('click', () => {
          if (current < total - 1) { current++; updatePagination(); }
        });
      }
    </script>
  </body>
</html>

<style>
  /* ---- HOMEPAGE MAIN ---- */
  .hp-main {
    height: calc(100vh - 9rem);
    overflow: hidden;
    position: relative;
    display: flex;
    flex-direction: column;
  }

  .hp-viewport {
    flex: 1;
    overflow: hidden;
    position: relative;
  }

  .hp-track {
    display: flex;
    height: 100%;
    transition: none;
    will-change: transform;
  }

  .hp-page {
    min-width: 100%;
    height: 100%;
    box-sizing: border-box;
    padding: 1.5rem 2rem;
  }

  /* ---- PAGE 1: FEATURED LAYOUT ---- */
  .hp-page-featured {
    display: flex;
    gap: 2rem;
  }

  .hp-featured-col {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
    min-width: 0;
  }

  .hp-card {
    text-decoration: none;
    color: #1C1D21;
    display: block;
    transition: opacity 0.2s ease;
  }

  .hp-card:hover {
    opacity: 0.8;
  }

  .hp-card-featured {
    flex: 1;
    display: flex;
    flex-direction: row;
    gap: 1.2rem;
    min-height: 0;
  }

  .hp-img-featured {
    height: 100%;
    aspect-ratio: 1 / 1;
    object-fit: cover;
    image-rendering: pixelated;
    display: block;
    flex-shrink: 0;
  }

  .hp-featured-text {
    flex: 1;
    display: flex;
    flex-direction: column;
    min-width: 0;
    overflow: hidden;
  }

  .hp-title {
    font-size: 1.8rem;
    font-weight: 500;
    text-transform: uppercase;
    color: #1C1D21;
    margin: 0 0 0.5rem 0;
    line-height: 1.3;
  }

  .hp-preview {
    font-size: 1.15rem;
    color: #1C1D21;
    margin: 0;
    line-height: 1.6;
    overflow: hidden;
    display: -webkit-box;
    -webkit-line-clamp: 6;
    -webkit-box-orient: vertical;
  }

  /* ---- GRID COLUMN (page 1 right side) ---- */
  .hp-grid-col {
    flex: 1;
    display: grid;
    grid-template-columns: 1fr 1fr;
    grid-template-rows: 1fr 1fr;
    gap: 1rem;
    min-width: 0;
  }

  .hp-card-standard {
    display: flex;
    flex-direction: column;
    min-height: 0;
  }

  .hp-img-standard {
    width: 100%;
    aspect-ratio: 3 / 2;
    object-fit: cover;
    image-rendering: pixelated;
    display: block;
  }

  .hp-title-sm {
    font-size: 1.3rem;
    font-weight: 500;
    text-transform: uppercase;
    color: #1C1D21;
    margin: 0.5rem 0 0 0;
    line-height: 1.3;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .hp-date {
    font-size: 0.85rem;
    color: #75798a;
    font-family: monospace;
    margin-top: 0.15rem;
  }

  .hp-featured-text .hp-date {
    margin-top: auto;
    padding-top: 0.4rem;
  }

  /* ---- PAGE 2+: FULL GRID ---- */
  .hp-page-full {
    display: flex;
    gap: 2rem;
  }

  /* ---- PAGINATION ---- */
  .hp-pagination {
    display: flex;
    justify-content: center;
    gap: 2rem;
    padding: 0.8rem 0;
    flex-shrink: 0;
  }

  .hp-page-btn {
    background: none;
    border: none;
    font-size: 0.95rem;
    font-weight: 500;
    color: #1C1D21;
    cursor: pointer;
    padding: 0.3rem 0.8rem;
    transition: color 0.2s ease;
    font-family: inherit;
  }

  .hp-page-btn:hover:not(:disabled) {
    color: #474747;
  }

  .hp-page-btn:disabled {
    color: #c8c0ab;
    cursor: default;
  }

  /* ---- MOBILE ---- */
  @media (max-width: 768px) {
    .hp-page-featured {
      flex-direction: column;
      overflow-y: auto;
    }

    .hp-card-featured {
      flex: none;
      height: auto;
    }

    .hp-img-featured {
      height: 8rem;
      width: 8rem;
    }

    .hp-preview {
      -webkit-line-clamp: 3;
    }

    .hp-grid-col {
      grid-template-columns: 1fr 1fr;
      grid-template-rows: auto;
    }

    .hp-page-full {
      flex-direction: column;
      overflow-y: auto;
    }

    .lc-header-icons {
      margin-right: 1rem;
      gap: 0.8rem;
    }

    .lc-header-btn-img {
      width: 2.5rem;
      height: 2.5rem;
    }
  }
</style>
