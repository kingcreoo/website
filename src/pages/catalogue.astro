---
import "../styles/global.css";
import Header from "../components/Header.astro";

const articleFiles = import.meta.glob('./articles/*.md', { eager: true });
const allArticles = Object.values(articleFiles) as any[];
const articles = allArticles
  .filter(a => !a.frontmatter.hidden)
  .filter(a => import.meta.env.DEV || !a.frontmatter.draft)
  .sort((a, b) => new Date(b.frontmatter.date).getTime() - new Date(a.frontmatter.date).getTime());

const PAGE_SIZE = 16;
const pages: any[][] = [];
for (let i = 0; i < articles.length; i += PAGE_SIZE) {
  pages.push(articles.slice(i, i + PAGE_SIZE));
}
const showPagination = articles.length > PAGE_SIZE;

function formatDate(date: string) {
  return new Date(date).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' });
}
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <title>Catalogue — Creoo Testing Lab</title>
  </head>
  <body>
    <Header />
    <main class="cat-main">
      {pages.map((page, pageIndex) => (
        <div class="cat-page" data-page={pageIndex} style={pageIndex > 0 ? "display:none" : ""}>
          <div class="cat-grid">
            {page.map(article => (
              <a href={article.url} class="cat-card">
                <img
                  src={article.frontmatter.image || '/images/rune-1.png'}
                  alt={article.frontmatter.title}
                  class="cat-img"
                />
                <h3 class="cat-title">{article.frontmatter.title}</h3>
                <span class="cat-date">{formatDate(article.frontmatter.date)}</span>
                {(article.frontmatter.lede || article.frontmatter.description) && (
                  <p class="cat-lede">{article.frontmatter.lede || article.frontmatter.description}</p>
                )}
              </a>
            ))}
          </div>
        </div>
      ))}

      {showPagination && (
        <div class="cat-pagination">
          <button class="cat-btn" id="cat-prev" disabled>&larr; Back</button>
          <button class="cat-btn" id="cat-next">Next &rarr;</button>
        </div>
      )}
    </main>

    <script>
      (() => {
        const pages = document.querySelectorAll<HTMLElement>('.cat-page');
        const prev = document.getElementById('cat-prev') as HTMLButtonElement | null;
        const next = document.getElementById('cat-next') as HTMLButtonElement | null;
        if (!pages.length || !prev || !next) return;

        let current = 0;
        const total = pages.length;

        function show(index: number) {
          pages.forEach((p, i) => { p.style.display = i === index ? '' : 'none'; });
          prev.disabled = index === 0;
          next.disabled = index === total - 1;
          window.scrollTo({ top: 0 });
        }

        prev.addEventListener('click', () => { if (current > 0) show(--current); });
        next.addEventListener('click', () => { if (current < total - 1) show(++current); });
      })();
    </script>
  </body>
</html>

<style>
  .cat-main {
    padding: 1.5rem 2rem 2rem;
  }

  .cat-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 2rem 1.5rem;
  }

  .cat-card {
    text-decoration: none;
    color: #1C1D21;
    display: flex;
    flex-direction: column;
    transition: opacity 0.2s ease;
  }

  .cat-card:hover {
    opacity: 0.8;
  }

  .cat-img {
    width: 100%;
    aspect-ratio: 3 / 2;
    object-fit: cover;
    display: block;
  }

  .cat-title {
    font-size: 1.1rem;
    font-weight: 500;
    margin: 0.6rem 0 0.15rem;
    line-height: 1.3;
  }

  .cat-date {
    font-family: monospace;
    font-size: 0.78rem;
    color: #75798a;
  }

  .cat-lede {
    font-size: 0.9rem;
    color: #75798a;
    margin: 0.4rem 0 0;
    line-height: 1.5;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .cat-pagination {
    display: flex;
    justify-content: center;
    gap: 2rem;
    padding: 2rem 0 0.5rem;
  }

  .cat-btn {
    background: none;
    border: none;
    font-size: 0.95rem;
    font-weight: 500;
    color: #1C1D21;
    cursor: pointer;
    padding: 0.3rem 0.8rem;
    font-family: inherit;
    transition: color 0.2s ease;
  }

  .cat-btn:hover:not(:disabled) {
    color: #474747;
  }

  .cat-btn:disabled {
    color: #c8c0ab;
    cursor: default;
  }

  @media (max-width: 768px) {
    .cat-main {
      padding: 1rem;
    }

    .cat-grid {
      grid-template-columns: repeat(2, 1fr);
      gap: 1.5rem 1rem;
    }
  }
</style>
