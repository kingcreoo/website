---
import ArticleGrid from "../components/ArticleGrid.astro";

const articleFiles = import.meta.glob('./articles/*.md', { eager: true });
const allArticles = Object.values(articleFiles) as any[];
const articles = allArticles
  .filter(a => !a.frontmatter.hidden)
  .filter(a => import.meta.env.DEV || !a.frontmatter.draft)
  .sort((a, b) => new Date(b.frontmatter.date).getTime() - new Date(a.frontmatter.date).getTime());
---

<ArticleGrid pageTitle="Catalogue" articles={articles} />
