---
import "../../styles/global.css";
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width" />
    <title>Layout A — Creoo Testing Lab</title>
  </head>
  <body>
    <div class="header-container">
      <img src="/images/rune-1.png" alt="Rune" class="header-image">
      <div class="header-texts">
        <a href="/" class="plain-link"><h1 class="header">Creoo Testing Lab</h1></a>
        <div class="header-2">
          <span>Welcome to my laboratory, wanderer.</span>
        </div>
      </div>
    </div>

    <hr class="header-divider">

    <main class="la-main">
      <aside class="la-sidebar">
        <a href="#" class="la-icon-btn">
          <img src="/images/rune-1.png" alt="Art Wall" class="la-icon-img" />
          <span class="la-icon-label">art wall</span>
        </a>
        <a href="#" class="la-icon-btn">
          <img src="/images/rune-1.png" alt="Construction" class="la-icon-img" />
          <span class="la-icon-label">construction</span>
        </a>
        <a href="#" class="la-icon-btn">
          <img src="/images/rune-1.png" alt="Archive" class="la-icon-img" />
          <span class="la-icon-label">archive</span>
        </a>
        <a href="#" class="la-icon-btn">
          <img src="/images/rune-1.png" alt="Metalog" class="la-icon-img" />
          <span class="la-icon-label">metalog</span>
        </a>
        <a href="#" class="la-icon-btn">
          <img src="/images/rune-1.png" alt="Catalog" class="la-icon-img" />
          <span class="la-icon-label">catalog</span>
        </a>
        <a href="#" class="la-icon-btn">
          <img src="/images/rune-1.png" alt="Open Source" class="la-icon-img" />
          <span class="la-icon-label">open source</span>
        </a>
      </aside>

      <div class="la-col-divider"></div>

      <section class="catalog-container la-catalog">
        <h1 class="catalog-title">Featured Catalog</h1>
        <div class="catalog-content">
          <a href="#" class="article-link">
            <div class="article-card la-article-big">
              <img src="/images/rune-1.png" alt="Featured" class="article-thumbnail la-big-thumb" />
              <div class="article-details">
                <h3 class="article-title">The Lowtech Loadout</h3>
                <p class="article-description">Why a Librebooted ThinkPad and a beater Subaru constitute a deliberate philosophy.</p>
                <span class="article-date">March 10, 2026</span>
              </div>
            </div>
          </a>

          <a href="#" class="article-link">
            <div class="article-card">
              <img src="/images/rune-1.png" alt="Thumb" class="article-thumbnail" />
              <div class="article-details">
                <h3 class="article-title">About This Site</h3>
                <p class="article-description">Its purpose, how it was made, and why it's on pause.</p>
                <span class="article-date">November 21, 2025</span>
              </div>
            </div>
          </a>

          <a href="#" class="article-link">
            <div class="article-card">
              <img src="/images/rune-1.png" alt="Thumb" class="article-thumbnail" />
              <div class="article-details">
                <h3 class="article-title">Algorithmic Curation and Discovery</h3>
                <p class="article-description">What recommendation engines do to both creators and consumers.</p>
                <span class="article-date">February 14, 2026</span>
              </div>
            </div>
          </a>

          <a href="#" class="article-link">
            <div class="article-card">
              <img src="/images/rune-1.png" alt="Thumb" class="article-thumbnail" />
              <div class="article-details">
                <h3 class="article-title">Raw Milk and First Principles</h3>
                <p class="article-description">Going to the source, questioning institutional consensus.</p>
                <span class="article-date">January 5, 2026</span>
              </div>
            </div>
          </a>
        </div>
      </section>

      <div class="la-col-divider"></div>

      <aside class="la-logs">
        <h2 class="la-logs-title">Recent Logs</h2>
        <ul class="la-logs-list">
          <li class="la-log-entry"><a href="#">P0302 Misfire<span class="la-log-date">Mar 15</span></a></li>
          <li class="la-log-entry"><a href="#">DR650 Spring Service<span class="la-log-date">Mar 14</span></a></li>
          <li class="la-log-entry"><a href="#">Libreboot T480 Flash Log<span class="la-log-date">Mar 12</span></a></li>
          <li class="la-log-entry"><a href="#">Route Notes: NJ to Maysville<span class="la-log-date">Mar 10</span></a></li>
          <li class="la-log-entry"><a href="#">OSE Week 12<span class="la-log-date">Mar 8</span></a></li>
          <li class="la-log-entry"><a href="#">Cake Wallet New UI<span class="la-log-date">Mar 6</span></a></li>
          <li class="la-log-entry"><a href="#">CV Axle Replacement<span class="la-log-date">Mar 3</span></a></li>
          <li class="la-log-entry"><a href="#">Monero Node Setup<span class="la-log-date">Feb 28</span></a></li>
          <li class="la-log-entry"><a href="#">Ranger Junkyard Find<span class="la-log-date">Feb 25</span></a></li>
          <li class="la-log-entry"><a href="#">Photogrammetry Results<span class="la-log-date">Feb 22</span></a></li>
          <li class="la-log-entry"><a href="#">T480 Battery Swap<span class="la-log-date">Feb 20</span></a></li>
          <li class="la-log-entry"><a href="#">Oil Change Notes<span class="la-log-date">Feb 18</span></a></li>
          <li class="la-log-entry"><a href="#">Chain Tension Adjustment<span class="la-log-date">Feb 15</span></a></li>
          <li class="la-log-entry"><a href="#">WireGuard Tunnel Debug<span class="la-log-date">Feb 12</span></a></li>
        </ul>
      </aside>
    </main>

    <div class="la-back"><a href="/layouts" class="plain-link">← back to switcher</a></div>
  </body>
</html>

<style>
  :global(html) {
    font-size: clamp(14px, 1vw, 22px);
  }

  /* ---- GLOBAL CLASS OVERRIDES (px → rem) ---- */
  :global(.header-image) {
    width: 6.25rem;
    height: 6.25rem;
  }
  :global(.header-container) {
    margin-left: 1rem;
    margin-top: 1rem;
    margin-bottom: 1rem;
  }
  :global(.article-thumbnail) {
    width: 9.4rem;
    height: 6.25rem;
  }
  :global(.catalog-content) {
    max-width: 50rem;
  }

  /* ---- LAYOUT A: 3-COL GRID ---- */
  .la-main {
    display: grid;
    grid-template-columns: 11.25rem 2px 1fr 2px 16.25rem;
    height: calc(100vh - 12.5rem);
    overflow: hidden;
    padding: 0 1rem;
  }

  /* ---- LEFT SIDEBAR ICON GRID ---- */
  .la-sidebar {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0.8rem;
    padding: 1rem 0.5rem;
    align-content: start;
  }
  .la-icon-btn {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-decoration: none;
    transition: opacity 0.2s ease;
  }
  .la-icon-btn:hover {
    opacity: 0.7;
  }
  .la-icon-img {
    width: 4rem;
    height: 4rem;
    image-rendering: pixelated;
    margin-bottom: 0.3rem;
  }
  .la-icon-label {
    font-size: 0.8rem;
    font-weight: 500;
    color: #1C1D21;
    text-align: center;
    text-transform: lowercase;
  }

  /* ---- COLUMN DIVIDERS ---- */
  .la-col-divider {
    background-color: #1C1D21;
    align-self: stretch;
  }

  /* ---- CENTER CATALOG OVERRIDES ---- */
  .la-catalog {
    padding-top: 1rem;
    padding-left: 1.5rem;
    align-items: flex-start;
  }
  .la-catalog .catalog-title {
    text-align: left;
    font-size: 1.8rem;
    margin: 0 0 1rem 0;
  }
  .la-big-thumb {
    width: 12.5rem;
    height: 8.125rem;
  }
  .la-article-big {
    padding-bottom: 1rem;
    margin-bottom: 1rem;
    border-bottom: 1px solid #c8c0ab;
  }

  /* ---- RIGHT LOGS ---- */
  .la-logs {
    padding: 1rem 0.5rem;
    overflow: hidden;
  }
  .la-logs-title {
    font-size: 1.2rem;
    font-weight: 500;
    text-transform: uppercase;
    color: #1C1D21;
    margin: 0 0 0.8rem 0;
  }
  .la-logs-list {
    list-style: none;
    padding: 0;
    margin: 0;
  }
  .la-log-entry {
    border-bottom: 1px solid #ddd5be;
  }
  .la-log-entry a {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 0.4rem 0;
    text-decoration: none;
    color: #1C1D21;
    font-size: 0.85rem;
  }
  .la-log-entry a:hover {
    color: #474747;
  }
  .la-log-date {
    font-family: monospace;
    font-size: 0.75rem;
    color: #75798a;
    flex-shrink: 0;
    margin-left: 0.5rem;
  }

  /* ---- BACK LINK ---- */
  .la-back {
    position: fixed;
    bottom: 0.5rem;
    left: 1rem;
  }
  .la-back a {
    font-size: 0.8rem;
    color: #75798a;
  }
</style>
