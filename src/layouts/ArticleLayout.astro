---
import "../styles/global.css";
import Header from "../components/Header.astro";
const { frontmatter } = Astro.props;

const slugify = (s: string) => s.toLowerCase().trim().replace(/\s+/g, '-').replace(/[^a-z0-9-]/g, '');
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <title>{frontmatter.title} — Creoo Testing Lab</title>
    {frontmatter.description && <meta name="description" content={frontmatter.description} />}
  </head>
  <body class="article-body">
    <Header />

    <main class="article-main">
      <article class="article-content">
        <header class="article-header">
          <h1 class="article-h1">{frontmatter.title}</h1>
          <div class="article-meta">
            <span class="article-meta-date">{new Date(frontmatter.date).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}</span>
            {frontmatter.author && (
              <span class="article-meta-author">Written by <a href={`/authors/${slugify(frontmatter.author)}`}>{frontmatter.author}</a></span>
            )}
            {frontmatter.tags && frontmatter.tags.length > 0 && (
              <div class="article-tags">
                {frontmatter.tags.map((tag: string) => (
                  <a href={`/tags/${tag}`} class="article-tag">{tag}</a>
                ))}
              </div>
            )}
          </div>
          {frontmatter.lede && (
            <p class="article-description-lede">{frontmatter.lede}</p>
          )}
        </header>

        <hr class="article-divider" />

        <div class="article-body-content">
          <slot />
        </div>
      </article>
    </main>
  </body>
</html>
